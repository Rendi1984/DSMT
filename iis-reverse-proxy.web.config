<?xml version="1.0" encoding="UTF-8"?>
<!--
  DSMT - OPTIONAL IIS reverse-proxy configuration.

  Use this ONLY if you want to serve the console and the API from a single
  origin/hostname (e.g. https://dsmt.lab.local) instead of pointing the
  console at http://<host>:8780 directly. Benefits: no CORS at all (same
  origin), one HTTPS binding, no port in the URL.

  Drop this file in as the console site's web.config
  (e.g. C:\inetpub\dsmt\web.config), then in the console's
  Settings -> Connection set the API base URL to the SITE's own URL with an
  EMPTY path - e.g. https://dsmt.lab.local  (no :8780, no /api). The console
  appends /api/... itself, and the rule below forwards /api/* to the API.

  PREREQUISITES (install once, server-wide):
    1. URL Rewrite module        (https://www.iis.net/downloads/microsoft/url-rewrite)
    2. Application Request Routing (ARR) (https://www.iis.net/downloads/microsoft/application-request-routing)
    3. In IIS Manager -> server node -> Application Request Routing Cache ->
       Server Proxy Settings -> tick "Enable proxy" -> Apply.
    Both modules are offline .msi installers - stage them in advance on an
    air-gapped server.

  IMPORTANT - DO NOT add Access-Control-Allow-* customHeaders here or anywhere
  on the /api path. The DSMT API already emits its own CORS headers; a second
  copy produces "Access-Control-Allow-Origin: *, *", which browsers reject
  outright (this was a real bug, fixed in 3.29.14 - don't reintroduce it).
  With this same-origin proxy setup CORS headers are not needed at all.

  Adjust the API host/port on the <action url="..."> line if your API does
  not listen on localhost:8780.
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- Forward every /api/* call to the DSMT-Api service. -->
        <rule name="DSMT API proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:8780/api/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Serve index.html for the site root. -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Static-content MIME safety (index.html is the only asset). -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

  </system.webServer>
</configuration>
